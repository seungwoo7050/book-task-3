APP_NAME=b-federation-security-lab
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
TOKEN_ISSUER=b-federation-security-lab-local
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/b_federation_security_lab
REDIS_URL=redis://redis:6379/0
ACCESS_TOKEN_TTL_SECONDS=900
PENDING_AUTH_TTL_SECONDS=300
REFRESH_TOKEN_TTL_SECONDS=1209600
SECURE_COOKIES=false
COOKIE_DOMAIN=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
GOOGLE_OIDC_CLIENT_ID=google-client-id
GOOGLE_OIDC_CLIENT_SECRET=google-client-secret
GOOGLE_OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_OIDC_AUTHORIZATION_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_OIDC_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
GOOGLE_OIDC_USERINFO_ENDPOINT=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_OIDC_JWKS_URI=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_OIDC_ISSUER=https://accounts.google.com
