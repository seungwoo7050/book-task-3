# rsum.ys

    .pos 0
    irmovq stack, %rsp
    irmovq ele1, %rdi
    call rsum_list
    halt

rsum_list:
    andq %rdi, %rdi
    je base_case

    mrmovq (%rdi), %rbx
    mrmovq 8(%rdi), %rdi
    pushq %rbx
    call rsum_list
    popq %rbx
    addq %rbx, %rax
    ret

base_case:
    irmovq $0, %rax
    ret

    .align 8
ele1:
    .quad 0x00a
    .quad ele2
ele2:
    .quad 0x0b0
    .quad ele3
ele3:
    .quad 0xc00
    .quad 0

    .pos 0x200
stack:
