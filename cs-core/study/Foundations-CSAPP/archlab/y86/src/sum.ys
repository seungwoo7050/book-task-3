# sum.ys

    .pos 0
    irmovq stack, %rsp
    irmovq ele1, %rdi
    call sum_list
    halt

sum_list:
    irmovq $0, %rax
    andq %rdi, %rdi
    je done

loop:
    mrmovq (%rdi), %r10
    addq %r10, %rax
    mrmovq 8(%rdi), %rdi
    andq %rdi, %rdi
    jne loop

done:
    ret

    .align 8
ele1:
    .quad 0x00a
    .quad ele2
ele2:
    .quad 0x0b0
    .quad ele3
ele3:
    .quad 0xc00
    .quad 0

    .pos 0x200
stack:
