{
  "title": "Workspace collaboration SaaS consolidated security review",
  "service": {
    "name": "workspace-api",
    "internet_exposed": true,
    "data_sensitivity": "high",
    "tenant_model": "multi-tenant"
  },
  "crypto_review": {
    "name": "workspace_session_crypto_gap",
    "surface": "session signing, password hashing, and key lifecycle",
    "controls": {
      "message_auth": "plain-sha256",
      "constant_time_compare": false,
      "password_kdf": "pbkdf2-hmac-sha1",
      "password_kdf_hardened": false,
      "key_separation": false,
      "rotation_defined": false
    },
    "expected_control_ids": [
      "CRYPTO-001",
      "CRYPTO-002",
      "CRYPTO-003",
      "CRYPTO-004"
    ]
  },
  "auth_scenarios": [
    {
      "name": "workspace_auth_hardening_gap",
      "flow": {
        "oauth_enabled": true,
        "uses_jwt": true,
        "uses_refresh_token": true,
        "cookie_session_mutation": true,
        "supports_recovery_codes": true
      },
      "controls": {
        "token_storage": "localStorage",
        "access_ttl_minutes": 45,
        "refresh_rotation": false,
        "reuse_detection": false,
        "issuer_validation": false,
        "audience_validation": false,
        "algorithm_pinning": false,
        "state_required": false,
        "pkce_required": false,
        "csrf_protection": false,
        "recovery_codes_hashed": false,
        "rate_limit_mode": "none"
      },
      "expected_control_ids": [
        "AUTH-001",
        "AUTH-002",
        "AUTH-003",
        "AUTH-004",
        "AUTH-005",
        "AUTH-006",
        "AUTH-007",
        "AUTH-008"
      ]
    }
  ],
  "backend_cases": [
    {
      "name": "workspace_export_gateway_gap",
      "surface": {
        "route": "/api/v1/workspaces/export-and-forward",
        "method": "POST",
        "database_touched": true,
        "object_lookup": true,
        "outbound_fetch": true,
        "can_raise_debug": true,
        "file_path_input": true
      },
      "controls": {
        "parameterized_queries": false,
        "ownership_scope_enforced": false,
        "outbound_allowlist": false,
        "private_ip_blocking": false,
        "debug_stacktrace_hidden": false,
        "safe_path_normalization": false
      },
      "expected_control_ids": [
        "OWASP-001",
        "OWASP-002",
        "OWASP-003",
        "OWASP-004",
        "OWASP-005"
      ]
    }
  ],
  "dependency_bundle": {
    "title": "Workspace dependency queue",
    "service_context": {
      "internet_exposed": true,
      "data_sensitivity": "high",
      "has_compensating_waf": true
    },
    "packages": [
      {
        "name": "openssl",
        "version": "3.0.11",
        "scope": "runtime",
        "direct": true,
        "reachable": true
      },
      {
        "name": "jwt-helper",
        "version": "1.4.2",
        "scope": "runtime",
        "direct": true,
        "reachable": true
      },
      {
        "name": "pytest",
        "version": "8.4.1",
        "scope": "dev",
        "direct": false,
        "reachable": false
      },
      {
        "name": "xml-lite",
        "version": "2.1.0",
        "scope": "runtime",
        "direct": false,
        "reachable": false
      }
    ],
    "advisories": [
      {
        "id": "CVE-2026-1001",
        "package": "openssl",
        "affected_version": "3.0.11",
        "severity": "critical",
        "public_exploit": true,
        "fix_version": "3.0.15"
      },
      {
        "id": "CVE-2026-1002",
        "package": "jwt-helper",
        "affected_version": "1.4.2",
        "severity": "high",
        "public_exploit": false,
        "fix_version": null
      },
      {
        "id": "CVE-2026-1003",
        "package": "pytest",
        "affected_version": "8.4.1",
        "severity": "medium",
        "public_exploit": false,
        "fix_version": "8.4.2"
      },
      {
        "id": "CVE-2026-1004",
        "package": "xml-lite",
        "affected_version": "2.1.0",
        "severity": "high",
        "public_exploit": false,
        "fix_version": "2.1.4"
      }
    ],
    "expected_items": [
      {
        "package": "openssl",
        "advisory_id": "CVE-2026-1001",
        "priority": "P1",
        "action": "upgrade-now",
        "recommended_version": "3.0.15"
      },
      {
        "package": "jwt-helper",
        "advisory_id": "CVE-2026-1002",
        "priority": "P2",
        "action": "monitor-with-compensating-control",
        "recommended_version": null
      },
      {
        "package": "pytest",
        "advisory_id": "CVE-2026-1003",
        "priority": "P4",
        "action": "document-and-expire",
        "recommended_version": null
      },
      {
        "package": "xml-lite",
        "advisory_id": "CVE-2026-1004",
        "priority": "P3",
        "action": "schedule-upgrade",
        "recommended_version": "2.1.4"
      }
    ]
  }
}
