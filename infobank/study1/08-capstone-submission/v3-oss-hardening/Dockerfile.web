FROM node:22-alpine

RUN corepack enable

WORKDIR /app

ARG NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3103
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY node/package.json node/package.json
COPY react/package.json react/package.json
COPY shared/package.json shared/package.json

RUN pnpm install --frozen-lockfile

COPY react ./react
COPY shared ./shared

RUN pnpm --filter @study1-v3/react build

EXPOSE 3003

CMD ["pnpm", "--filter", "@study1-v3/react", "start"]
